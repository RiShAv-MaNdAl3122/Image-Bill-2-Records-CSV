# pyenv
#   For a list of Python versions that you want to ignore see
#   https://github.com/github/gitignore/blob/main/Global/Python.gitignore
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you are having trouble with it, uncomment the line below.
#Lock

# poetry
#   poetry.lock is usually committed, but if you want to ignore it:
#poetry.lock

# pdm
#   pdm.lock is usually committed, but if you want to ignore it:
#pdm.lock
.pdm-plugins/
.pdm-build/

